# Port to run the server on
PORT=5000

# Environment (development | production)
NODE_ENV=development

# MongoDB Connection URL
DB_URL=mongodb://localhost:27017/my-database

# Authentication System (passport | custom)
AUTH_SYSTEM=custom

# JWT Configuration
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Password Hashing
BCRYPT_SALT_ROUND=10

# Frontend URL for CORS and Redirects
FRONTEND_URL=http://localhost:3000

# Express Session Secret (required if AUTH_SYSTEM=passport)
EXPRESS_SESSION_SECRET=your_session_secret_here

# Super Admin Credentials (for initial seeding)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=admin_password_123
SUPER_ADMIN_PHONE=01234567890

# Google OAuth (required if AUTH_SYSTEM=passport)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FORM="Your App <no-reply@yourapp.com>"
